# ── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/berryguard.db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=900

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_EXCHANGE=berryguard
RABBITMQ_QUEUE=climate_events
RABBITMQ_ROUTING_KEY=climate.data

# ── Localização Padrão ────────────────────────────────────────────────────────
DEFAULT_LATITUDE=-23.5505
DEFAULT_LONGITUDE=-46.6333
DEFAULT_LOCATION_NAME=São Paulo, SP

# ── Thresholds ────────────────────────────────────────────────────────────────
DEFAULT_MIN_TEMPERATURE=2.0
DEFAULT_MAX_HUMIDITY=90.0
